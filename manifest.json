{
  "manifest_version": "0.3",
  "name": "halopsa-mcp",
  "display_name": "HaloPSA MCP Server",
  "version": "0.0.0",
  "description": "MCP server for HaloPSA - access tickets, clients, assets, and invoices through AI assistants",
  "long_description": "Provides AI assistants with structured access to your HaloPSA data. Manage tickets, clients, assets, invoices, and contracts through the Model Context Protocol.",
  "author": { "name": "Wyre Technology", "url": "https://github.com/wyre-technology" },
  "repository": { "type": "git", "url": "https://github.com/wyre-technology/halopsa-mcp" },
  "homepage": "https://github.com/wyre-technology/halopsa-mcp",
  "license": "Apache-2.0",
  "keywords": ["halopsa", "psa", "msp", "tickets", "it-management"],
  "server": {
    "type": "node",
    "entry_point": "dist/index.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/dist/index.js"],
      "env": { "HALOPSA_CLIENT_ID": "${user_config.halopsa_client_id}", "HALOPSA_CLIENT_SECRET": "${user_config.halopsa_client_secret}", "HALOPSA_TENANT": "${user_config.halopsa_tenant}", "HALOPSA_BASE_URL": "${user_config.halopsa_base_url}", "MCP_TRANSPORT": "stdio" }
    }
  },
  "tools_generated": true,
  "user_config": {
    "halopsa_client_id": { "type": "string", "title": "HaloPSA Client ID", "description": "Your HaloPSA OAuth client ID", "sensitive": true, "required": true },
    "halopsa_client_secret": { "type": "string", "title": "HaloPSA Client Secret", "description": "Your HaloPSA OAuth client secret", "sensitive": true, "required": true },
    "halopsa_tenant": { "type": "string", "title": "HaloPSA Tenant", "description": "Your HaloPSA tenant name (optional)", "sensitive": false, "required": false },
    "halopsa_base_url": { "type": "string", "title": "HaloPSA Base URL", "description": "Custom HaloPSA base URL (optional)", "sensitive": false, "required": false }
  },
  "compatibility": { "platforms": ["darwin", "win32", "linux"], "runtimes": { "node": ">=18.0.0" }, "claude_desktop": ">=0.10.0" }
}
